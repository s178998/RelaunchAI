# ============================================================
# MONOREPO .gitignore
# Next.js frontend · Python backend · Docker
# ============================================================


# ─── OS & EDITORS ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~


# ─── NEXT.JS FRONTEND ───────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/.turbo/

# Dependencies
frontend/node_modules/

# Environment
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Cache & telemetry
frontend/.eslintcache
frontend/tsconfig.tsbuildinfo
frontend/.next/cache/
frontend/next-env.d.ts


# ─── PYTHON BACKEND ─────────────────────────────────────────
# Byte-compiled / optimized / DLL files
backend/__pycache__/
backend/**/__pycache__/
**/*.py[cod]
**/*$py.class

# Virtual environments
backend/.venv/
backend/venv/
backend/env/
backend/ENV/
.python-version

# Distribution / packaging
backend/dist/
backend/build/
backend/*.egg-info/
backend/.eggs/

# Test & coverage
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/coverage.xml
backend/.tox/

# Type checking
backend/.mypy_cache/
backend/.dmypy.json

# Linting
backend/.ruff_cache/

# Environment
backend/.env
backend/.env.local
backend/.env.*
!backend/.env.example

# Logs
backend/logs/
backend/*.log

# Celery
backend/celerybeat-schedule
backend/celerybeat.pid

# Local DB / uploads (if applicable)
backend/*.sqlite3
backend/*.db
backend/uploads/
backend/media/


# ─── DOCKER ─────────────────────────────────────────────────
.docker/
docker-compose.override.yml
docker-compose.local.yml

# Don't ignore example overrides
!docker-compose.override.yml.example

# Container volumes mounted locally
.volumes/
data/
postgres-data/
redis-data/


# ─── ENVIRONMENT & SECRETS (ROOT) ───────────────────────────
.env
.env.local
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/


# ─── DEPENDENCY LOCK FILES (keep these!) ────────────────────
# Remove the lines below if you prefer not to commit lock files
# frontend/package-lock.json
# frontend/yarn.lock
# frontend/pnpm-lock.yaml
# backend/poetry.lock


# ─── LOGS & MISC ────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.cache/
tmp/
temp/
node_modules/
*.csv